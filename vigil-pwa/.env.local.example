# vigil-pwa/.env.local.example — LOCAL DEV ONLY (Phase 107.2 D-C3)
# Copy to .env.local; .env.local is gitignored (vigil-pwa/.gitignore or repo .gitignore).
# Vite auto-loads .env.local in dev — takes precedence over .env.

# ---------------------------------------------------------------------------
# VITE_API_BASE — browser-side API base URL (import.meta.env.VITE_API_BASE)
# ---------------------------------------------------------------------------
# LEAVE UNSET IN DEV (Phase 107.2 D-C1 + Pitfall 4).
# When unset, vigil-pwa/src/api/client.ts falls through to `import.meta.env.DEV ? ''`
# which means API_BASE='' → fetch('/v1/x') stays same-origin → Vite proxy routes
# it to VITE_DEV_API_TARGET (below). That's what makes cross-machine dev work
# from a MacBook Pro browser hitting http://jamesons-imac-2:5173 — no direct
# laptop→iMac API call, the proxy does it server-side on the iMac.
# Prod builds default to 'https://api.vigilhub.io' via the same client.ts fallback.
# VITE_API_BASE=

# ---------------------------------------------------------------------------
# VITE_DEV_API_TARGET — Vite dev-server proxy target for /v1/*
# ---------------------------------------------------------------------------
# Read at Vite startup via loadEnv() in vite.config.ts. Default is
# http://localhost:3001 (local vigil-core running in the same `npm run dev`).
# Override only for staging integration tests or unusual local setups
# (e.g., pointing /v1 at a Railway preview deployment).
VITE_DEV_API_TARGET=http://localhost:3001

# ---------------------------------------------------------------------------
# VITE_ALLOWED_HOSTS — Vite DNS rebinding allowlist (server.allowedHosts)
# ---------------------------------------------------------------------------
# Comma-separated host list. Leave UNSET for permissive default (allow any
# Host header) — consistent with D-D1 "Tailscale is the real perimeter" for
# cross-machine dev. MagicDNS hostnames like `jamesons-imac-2` require this
# to be either permissive or explicitly listed; Vite 5+ blocks by default.
# Example tight scope: VITE_ALLOWED_HOSTS=jamesons-imac-2,jamesons-imac-2.tail-scale.ts.net
# VITE_ALLOWED_HOSTS=
