# vigil-core/.env — LOCAL DEV ONLY.
# After Phase 107.1, prod secrets live ONLY in Railway (per RUNBOOK Secret-drift policy).
# This file is the template consumed by scripts/dev-setup.sh (Phase 107.1 Plan 03).
# Copy to .env and fill in real values; .env is gitignored (root .gitignore line 9-12).

# --- Database ---
# Local Postgres (Homebrew postgresql@16). NOT a remote production host.
# DO NOT put a remote hostname here — pre-flight check (Plan 03) will reject it.
DATABASE_URL=postgresql://localhost:5432/vigil_dev

# --- JWT ---
# Dev-only signing secret. Must be >= 32 characters (src/utils/jwt.ts boot check).
# Generate a fresh random value for local; Railway prod has its own independent JWT_SECRET.
JWT_SECRET=replace-me-with-32-plus-random-bytes-for-local-dev-only

# --- Allowed emails (register/login gate) ---
# Comma-separated list. Must include the seed user email (see scripts/seed-local.ts in Plan 02).
# Empty list → POST /v1/auth/register returns 403 (src/routes/auth.ts:43).
VIGIL_ALLOWED_EMAILS=jamesonmorrill1@gmail.com

# --- Anthropic API key (DEV workspace only) ---
# Per D-18: dev-scoped key in a separate Anthropic workspace with $20/mo spend cap.
# This is EXPECTED to differ from the prod Railway key — dailybrief-doctor.sh Plan 07
# has been taught to treat local/prod Anthropic-key divergence as normal, NOT drift.
ANTHROPIC_API_KEY=sk-ant-dev-workspace-key-here

# --- PostHog (leave blank locally) ---
# Per Phase 103 Plan 01 key-absence gate: blank POSTHOG_API_KEY disables capture.
# Railway prod has the real key; local dev events do NOT hit PostHog Cloud.
POSTHOG_API_KEY=

# --- Google OAuth secrets ---
# Both required at vigil-core startup (src/index.ts:51 FATAL check).
# GOOGLE_OAUTH_STATE_SECRET: >=32 chars, used as HMAC key for OAuth state tokens (src/routes/google-auth.ts:66).
#   Generate: `openssl rand -base64 32`
# GOOGLE_TOKEN_ENCRYPTION_KEY: exactly 64-char hex (32 bytes) for OAuth token-at-rest encryption (src/utils/token-crypto.ts:11).
#   Generate: `openssl rand -hex 32`
# Dev values are locally generated; Railway prod has its own independent values.
GOOGLE_OAUTH_STATE_SECRET=replace-with-openssl-rand-base64-32-output
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32-output

# --- Google OAuth client (optional locally) ---
# Only required if you run actual Gmail/Calendar OAuth flows during local dev.
# Leave blank to skip OAuth flows; server starts fine without these.
# Per work-order source pivot, Gmail ingest is paused — these stay empty until the
# ServiceNow pivot or Gmail re-enablement.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/google/callback

# --- Port ---
# Must be 3001 (D-11) — same port the retired com.jamesonmorrill.vigilcore daemon used,
# so Google OAuth redirect URI (http://localhost:3001/v1/auth/google/callback) stays valid.
PORT=3001

# --- Bind hostname (LOCAL ONLY — Railway MUST leave this unset) ---
# Phase 107.2 D-B1/D-B2 — cross-machine Tailscale dev access.
# Default (unset) = 127.0.0.1 = localhost-only (prod-safe behind Railway proxy).
# Set to 0.0.0.0 in local dev to allow Tailscale/LAN peers to reach :3001.
# See vigil-core/RUNBOOK.md → "Cross-machine dev access" for the full workflow.
#
# DO NOT set this on Railway. Railway's prod guard (src/index.ts) additionally
# fail-closes if CORS_ORIGINS is unset in production — this env var being
# 0.0.0.0 in prod would still be a misconfiguration. Belt-and-suspenders.
#
# Uncomment the line below to enable cross-machine Tailscale/LAN dev access;
# leave commented for localhost-only (the safe default the doc describes).
#VIGIL_BIND_HOST=0.0.0.0

# --- Resend transactional email (leave blank locally) ---
# Per Phase 111 D-10/D-12 key-absence gate: blank RESEND_API_KEY disables sending.
# Wrappers (sendPasswordResetEmail, sendEmailVerificationEmail) return
# { status: "skipped_no_key" } when unset — routes still return 200 to callers
# (AUTH-10 enumeration safety). Generate a key at https://resend.com/api-keys
# and set it on Railway only; local dev does NOT send real email.
RESEND_API_KEY=

# --- App base URL for email links (LOCAL vs Railway) ---
# Per Phase 111 D-05/D-06: route handlers construct full reset/verify URLs
# against this origin before calling email-service wrappers. Decoupled from
# CORS_ORIGINS on purpose (different concerns — do not reuse).
# Local dev: Vite default origin (http://localhost:5173).
# Railway prod: https://app.vigilhub.io (set in Railway Variables).
VIGIL_APP_BASE_URL=http://localhost:5173
