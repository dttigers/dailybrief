<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- CloudKit entitlements removed 2026-04-09 (Phase 58): dead code,    -->
    <!-- incompatible with Developer ID signing without provisioning.       -->
    <!--                                                                    -->
    <!-- Ubiquity (iCloud Drive — different entitlement family from         -->
    <!-- CloudKit) restored 2026-05-19 (Phase 999.1) to enable native       -->
    <!-- startDownloadingUbiquitousItem on iCloud Notebook HEIC stubs.      -->
    <!-- Authorized by embedded.provisionprofile. See 999.1-RESEARCH.md.    -->
    <!--                                                                    -->
    <!-- 2026-05-19 hotfix: container ID must be team-prefixed literal      -->
    <!-- (5H57ADQS8G.iCloud.<bundle>) to match Developer ID profiles'       -->
    <!-- wildcard ubiquity entitlement (5H57ADQS8G.*). amfid policy is      -->
    <!-- "ALL array entries must match the profile's allow-list" — adding   -->
    <!-- a friendly 'iCloud.<bundle>' entry breaks amfid (entry doesn't     -->
    <!-- start with the team prefix, so wildcard match fails for THAT       -->
    <!-- entry, even if a sibling entry matches).                           -->
    <!--                                                                    -->
    <!-- The friendly 'iCloud.<bundle>' identifier is NOT in the            -->
    <!-- entitlement. Instead, it's declared in the bundle's Info.plist     -->
    <!-- as NSUbiquitousContainers key. bird/cloudd reads Info.plist to     -->
    <!-- discover container metadata; the entitlement only needs to         -->
    <!-- satisfy amfid. See Scripts/install.sh Info.plist generation        -->
    <!-- (NSUbiquitousContainers block) for the bird-side declaration.      -->
    <key>com.apple.developer.ubiquity-container-identifiers</key>
    <array>
        <string>5H57ADQS8G.iCloud.com.jamesonmorrill.dailybriefmonitor</string>
    </array>
</dict>
</plist>
