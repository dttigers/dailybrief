<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- CloudKit entitlements removed 2026-04-09 (Phase 58): dead code,    -->
    <!-- incompatible with Developer ID signing without provisioning.       -->
    <!--                                                                    -->
    <!-- Ubiquity (iCloud Drive — different entitlement family from         -->
    <!-- CloudKit) restored 2026-05-19 (Phase 999.1) to enable native       -->
    <!-- startDownloadingUbiquitousItem on iCloud Notebook HEIC stubs.      -->
    <!-- Authorized by embedded.provisionprofile. See 999.1-RESEARCH.md.    -->
    <!--                                                                    -->
    <!-- 2026-05-19 hotfix: container ID must be team-prefixed literal      -->
    <!-- (5H57ADQS8G.iCloud.<bundle>) to match Developer ID profiles'       -->
    <!-- wildcard ubiquity entitlement (5H57ADQS8G.*). The friendly         -->
    <!-- iCloud.<bundle> form works for Mac App Store profiles (literal     -->
    <!-- entries) but not Developer ID (wildcard) — amfid -413 if missing.  -->
    <!-- See Plan 04 hotfix commit for the failure-mode evidence.           -->
    <key>com.apple.developer.ubiquity-container-identifiers</key>
    <array>
        <string>5H57ADQS8G.iCloud.com.jamesonmorrill.dailybriefmonitor</string>
    </array>
</dict>
</plist>
