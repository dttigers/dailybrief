{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "typeRoots": [
      "../vigil-core/node_modules/@types",
      "../vigil-pwa/node_modules/@types"
    ],
    "types": ["node"]
  },
  "include": ["./*.test.ts"]
}
